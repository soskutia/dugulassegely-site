---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props as Props;
---

<section
  id="munka-kozben"
  class="border-b border-slate-800 bg-[#020617]"
  aria-labelledby="munka-kozben-heading"
>
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8 space-y-2 text-center">
      <h2
        id="munka-kozben-heading"
        class="text-2xl font-semibold tracking-tight text-slate-50 md:text-3xl"
      >
        Munka közben
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-slate-300">
        Valódi helyszíni munkáinkból válogattunk néhány jellemző példát – túlzás nélkül, a
        mindennapi gyakorlatot mutatva.
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <figure
          class="group flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/70 text-sm text-slate-200 shadow-[0_16px_40px_rgba(15,23,42,0.9)]"
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-slate-900">
            <img
              src={item.imageSrc ?? `/images/work/${item.id}.jpg`}
              alt={item.imageAlt ?? item.title}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03] group-hover:brightness-110"
            />
            {item.district && (
              <div class="absolute left-2 top-2 rounded-full bg-black/55 px-2.5 py-1 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-slate-50">
                {item.district}
              </div>
            )}
            {item.context && (
              <div class="absolute bottom-2 left-2 rounded-full bg-slate-900/80 px-2.5 py-1 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-slate-100">
                {item.context}
              </div>
            )}
          </div>
          <figcaption class="flex flex-1 flex-col gap-1 px-4 py-3">
            <h3 class="text-sm font-semibold text-slate-50">
              {item.title}
            </h3>
            <p class="text-xs text-slate-300">
              {item.description}
            </p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

