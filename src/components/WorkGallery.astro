---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props as Props;
---

<section
  id="munka-kozben"
  class="border-b border-[var(--ds-border-subtle)] bg-[var(--ds-section)]"
  aria-labelledby="munka-kozben-heading"
>
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8 space-y-2 text-center">
      <h2
        id="munka-kozben-heading"
        class="text-2xl font-semibold tracking-tight text-[var(--ds-text-primary)] md:text-3xl"
      >
        Munka közben
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-[var(--ds-text-secondary)]">
        Valódi helyszíni munkáimból válogattam néhány jellemző példát – túlzás nélkül, a
        mindennapi gyakorlatot mutatva.
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <figure
          class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--ds-border-default)] bg-[var(--ds-surface)] text-sm text-[var(--ds-text-secondary)] shadow-[var(--ds-shadow-soft)] transition-transform transition-shadow hover:-translate-y-0.5 hover:shadow-[var(--ds-shadow-elevated)]"
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-slate-200">
            <img
              src={item.imageSrc ?? `/images/work/${item.id}.webp`}
              alt={item.imageAlt ?? item.title}
              loading="lazy"
              decoding="async"
              width="1600"
              height="900"
              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03] group-hover:brightness-110"
            />
            {item.district && (
              <div class="absolute left-2 top-2 rounded-full bg-white/90 px-2.5 py-1 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-slate-800 border border-[var(--ds-border-subtle)]">
                {item.district}
              </div>
            )}
            {item.context && (
              <div class="absolute bottom-2 left-2 rounded-full bg-white/90 px-2.5 py-1 text-[0.68rem] font-medium uppercase tracking-[0.14em] text-slate-800 border border-[var(--ds-border-subtle)]">
                {item.context}
              </div>
            )}
          </div>
          <figcaption class="flex flex-1 flex-col gap-1 px-4 py-3">
            <h3 class="text-sm font-semibold text-[var(--ds-text-primary)]">
              {item.title}
            </h3>
            <p class="text-xs text-[var(--ds-text-secondary)]">
              {item.description}
            </p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

