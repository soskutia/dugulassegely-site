---
import type { FaqItem } from '../data/faqs';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props as Props;
---

<section
  id="gyik"
  class="border-b border-slate-800 bg-[#020617]"
  aria-labelledby="gyik-heading"
>
  <div class="mx-auto max-w-3xl px-4 py-12 md:py-16">
    <header class="mb-6 space-y-2 text-center">
      <h2 id="gyik-heading" class="text-2xl font-semibold tracking-tight text-slate-50 md:text-3xl">
        Gyakori kérdések
      </h2>
      <p class="text-sm text-slate-300">
        Összegyűjtöttem a legfontosabb kérdéseket a duguláselhárítással kapcsolatban.
      </p>
    </header>
    <div class="space-y-3">
      {items.map((faq) => (
        <details class="group rounded-xl border border-slate-800 bg-slate-900/70 px-4 py-3">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-medium text-slate-50">
            <span>{faq.question}</span>
            <span class="text-xs text-slate-400 group-open:hidden" aria-hidden="true">
              Megnyitás
            </span>
            <span class="hidden text-xs text-slate-400 group-open:inline" aria-hidden="true">
              Bezárás
            </span>
          </summary>
          <div class="mt-2 text-sm leading-relaxed text-slate-300">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

