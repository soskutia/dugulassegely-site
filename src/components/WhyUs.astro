---
import { benefits } from '../data/benefits';
---

<section
  id="mierten"
  class="border-b border-[var(--ds-border-subtle)] bg-[var(--ds-section)]"
  aria-labelledby="mierten-heading"
>
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8 space-y-2 text-center">
      <h2
        id="mierten-heading"
        class="text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl"
      >
        Miért engem hívjon?
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-[var(--ds-text-secondary)]">
        Duguláselhárításnál számít, ki érkezik a helyszínre.
        <br />
        Kovács Róbert vagyok, duguláselhárító szakember – gyors reakcióidővel, tiszta
        munkavégzéssel és előre kiszámítható költségekkel dolgozom.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {benefits.map((benefit) => (
        <article
          class="flex items-start gap-2 rounded-2xl border border-[var(--ds-border-subtle)] bg-[var(--ds-surface)] p-4 text-sm text-[var(--ds-text-secondary)] shadow-[0_16px_40px_rgba(15,23,42,0.8)] transition-transform transition-shadow hover:-translate-y-0.5 hover:shadow-[var(--ds-shadow-elevated)]"
        >
          <div
            class="flex flex-none items-center justify-center text-base"
            aria-hidden="true"
          >
            {benefit.id === 'gyors-kiszallas' && '⚡'}
            {benefit.id === 'gepesitett-megoldasok' && '🛠️'}
            {benefit.id === 'tiszta-munkavegzes' && '🧼'}
            {benefit.id === 'atlathato-arazas' && '💰'}
          </div>
          <div class="space-y-1">
            <h3 class="text-sm font-semibold text-[var(--ds-text-primary)]">
              {benefit.title}
            </h3>
            <p class="text-sm text-[var(--ds-text-secondary)]">
              {benefit.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
