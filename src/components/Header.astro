---
import BrandLogo from './BrandLogo.astro';
---

<header class="sticky top-0 z-40 border-b border-slate-800 bg-[#020617]/90 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4">
    <input
      id="main-nav-toggle"
      type="checkbox"
      class="peer sr-only"
      aria-hidden="true"
      tabindex="-1"
    />

    <div class="flex h-16 items-center justify-between gap-3">
      <BrandLogo />

      <nav
        class="hidden items-center gap-8 text-sm font-medium text-slate-200 md:flex"
        aria-label="Fő navigáció"
      >
        <a href="#szolgaltatasok" class="transition-colors hover:text-[#2563EB]">
          Szolgáltatások
        </a>
        <a href="#miert-mi" class="transition-colors hover:text-[#2563EB]">
          Miért én
        </a>
        <a href="#velemenyek" class="transition-colors hover:text-[#2563EB]">
          Vélemények
        </a>
        <a href="#gyik" class="transition-colors hover:text-[#2563EB]">
          GYIK
        </a>
        <a href="#kapcsolat" class="transition-colors hover:text-[#2563EB]">
          Kapcsolat
        </a>
      </nav>

      <div class="flex items-center gap-3 md:gap-4">
        <a
          href="tel:+36305382048"
          class="inline-flex items-center gap-2 rounded-full bg-[#EF4444] px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-white shadow-[0_10px_30px_rgba(248,113,113,0.45)] transition hover:bg-[#DC2626]"
          aria-label="Azonnali hívás a DugulásSegély szerelőjének"
        >
          <span aria-hidden="true" class="flex h-4 w-4 items-center justify-center">
            <svg
              viewBox="0 0 24 24"
              class="h-3.5 w-3.5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.08 4.18 2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72c.12.9.37 1.77.72 2.6a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.48-1.24a2 2 0 0 1 2.11-.45c.83.35 1.7.6 2.6.72A2 2 0 0 1 22 16.92Z" />
            </svg>
          </span>
          <span>Hívás most</span>
        </a>

        <label
          for="main-nav-toggle"
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-slate-700/70 bg-slate-900/60 text-slate-200 shadow-sm ring-0 transition hover:border-slate-500/80 md:hidden"
          aria-label="Navigációs menü megnyitása"
        >
          <span class="flex flex-col gap-[5px]">
            <span class="h-[2px] w-4 rounded-full bg-slate-200"></span>
            <span class="h-[2px] w-3 rounded-full bg-slate-400"></span>
            <span class="h-[2px] w-4 self-end rounded-full bg-slate-200"></span>
          </span>
        </label>
      </div>
    </div>

    <nav
      class="grid grid-rows-[0fr] border-t border-slate-800/60 text-sm text-slate-200 transition-[grid-template-rows] duration-200 ease-out peer-checked:grid-rows-[1fr] md:hidden"
      aria-label="Fő navigáció mobil"
    >
      <div class="overflow-hidden">
        <div class="flex flex-col gap-2 py-3 text-sm font-medium">
          <a href="#szolgaltatasok" class="rounded-lg px-1 py-1.5 hover:text-[#2563EB]">
            Szolgáltatások
          </a>
          <a href="#miert-mi" class="rounded-lg px-1 py-1.5 hover:text-[#2563EB]">
            Miért mi
          </a>
          <a href="#velemenyek" class="rounded-lg px-1 py-1.5 hover:text-[#2563EB]">
            Vélemények
          </a>
          <a href="#gyik" class="rounded-lg px-1 py-1.5 hover:text-[#2563EB]">
            GYIK
          </a>
          <a href="#kapcsolat" class="rounded-lg px-1 py-1.5 hover:text-[#2563EB]">
            Kapcsolat
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>
