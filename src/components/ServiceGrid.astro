---
import type { Service } from '../data/services';

interface Props {
  services: Service[];
}

const { services } = Astro.props as Props;
---

<section id="szolgaltatasok" class="border-b border-slate-800 bg-[#020617]">
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8 space-y-2 text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-50 md:text-3xl">
        Főbb szolgáltatásaim
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-slate-300">
        Lakásoktól a társasházakig, a kisebb lefolyó dugulástól a teljes strang tisztításáig mindent vállalok.
      </p>
    </header>
    <div class="grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <article
          class="flex flex-col rounded-2xl border border-slate-800 bg-slate-900/70 p-5 text-sm text-slate-200 shadow-[0_16px_40px_rgba(15,23,42,0.9)]"
        >
          <div class="mb-3 h-1 w-10 rounded-full bg-gradient-to-r from-[#2563EB] to-[#38BDF8]" />
          <h3 class="mb-2 text-base font-semibold text-slate-50">{service.title}</h3>
          <p class="mb-4 text-sm text-slate-300">{service.description}</p>
          <div class="mt-auto flex items-center justify-between pt-2 text-xs text-slate-400">
            <span>Díjmentes telefonos konzultáció • Rövid határidő</span>
            {service.url && (
              <a
                href={service.url}
                class="ml-2 whitespace-nowrap text-[#2563EB] hover:text-[#60A5FA]"
              >
                Részletek
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

