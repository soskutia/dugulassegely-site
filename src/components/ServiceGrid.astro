---
import type { Service } from '../data/services';

interface Props {
  services: Service[];
}

const { services } = Astro.props as Props;
---

<section id="szolgaltatasok" class="border-b border-[var(--ds-border-subtle)] bg-[var(--ds-section)]">
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="mb-8 space-y-2 text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
        Főbb szolgáltatásaim
      </h2>
      <p class="mx-auto max-w-2xl text-sm text-[var(--ds-text-secondary)]">
        Lakásoktól a társasházakig, a kisebb lefolyó dugulástól a teljes strang tisztításáig mindent vállalok.
      </p>
    </header>
    <div class="grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <article
          class="flex flex-col rounded-2xl border border-[var(--ds-border-default)] bg-[var(--ds-surface)] p-5 text-sm text-[var(--ds-text-secondary)] shadow-[var(--ds-shadow-soft)] transition-transform transition-shadow hover:-translate-y-0.5 hover:shadow-[var(--ds-shadow-elevated)]"
        >
          <div class="mb-3 h-1 w-10 rounded-full bg-gradient-to-r from-[var(--ds-primary)] to-[#38BDF8]" />
          <h3 class="mb-2 text-base font-semibold text-[var(--ds-text-primary)]">{service.title}</h3>
          <p class="mb-4 text-sm text-[var(--ds-text-secondary)]">{service.description}</p>
          <div class="mt-auto flex items-center justify-between pt-2 text-xs text-[var(--ds-text-muted)]">
            <span>Díjmentes telefonos konzultáció • Rövid határidő</span>
            {service.url && (
              <a
                href={service.url}
                class="ml-2 whitespace-nowrap text-[var(--ds-primary)] hover:text-blue-600 underline-offset-4 hover:underline"
              >
                Részletek
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

