---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props as Props;
const checkboxId = `legal-modal-${id}`;
const headingId = `${checkboxId}-title`;
---

<div class="relative">
  <input id={checkboxId} type="checkbox" class="peer hidden" />

  <label
    for={checkboxId}
    class="cursor-pointer hover:text-slate-300"
  >
    {title}
  </label>

  <div
    class="pointer-events-none fixed inset-0 z-50 flex items-center justify-center bg-black/60 opacity-0 transition peer-checked:pointer-events-auto peer-checked:opacity-100"
  >
    <label for={checkboxId} class="absolute inset-0" aria-hidden="true"></label>

    <div
      role="dialog"
      aria-modal="true"
      aria-labelledby={headingId}
      class="relative mx-4 max-h-[80vh] w-full max-w-lg overflow-hidden rounded-2xl border border-slate-700 bg-slate-900 p-5 text-sm text-slate-200 shadow-[0_24px_60px_rgba(0,0,0,0.75)]"
    >
      <header class="mb-3 flex items-start justify-between gap-4">
        <h2 id={headingId} class="text-sm font-semibold text-slate-50">
          {title}
        </h2>
        <label
          for={checkboxId}
          class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full border border-slate-700 bg-slate-900 text-xs text-slate-300 hover:border-slate-500 hover:text-slate-100"
          aria-label="Jogi ablak bezárása"
        >
          ✕
        </label>
      </header>

      <div class="max-h-[52vh] space-y-2 overflow-y-auto pr-1 text-xs leading-relaxed text-slate-200">
        <slot />
      </div>

      <div class="mt-4 flex justify-end text-[0.7rem] text-slate-400">
        <label
          for={checkboxId}
          class="cursor-pointer hover:text-slate-100"
        >
          Bezárás
        </label>
      </div>
    </div>
  </div>
</div>

