---
import LegalModalLink from './LegalModalLink.astro';
import ImpresszumContent from './legal/ImpresszumContent.astro';
import AdatkezelesContent from './legal/AdatkezelesContent.astro';
import CookieContent from './legal/CookieContent.astro';
import FelhasznalasContent from './legal/FelhasznalasContent.astro';
---

<footer class="border-t border-slate-800 bg-[var(--ds-footer-bg)]">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-8 text-sm text-slate-300 md:flex-row md:items-start md:justify-between"
  >
    <div>
      <div class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-100">
        DUGULÁSSEGÉLY
      </div>
      <p class="mt-1 text-sm text-slate-400">
        Gyors, tiszta duguláselhárítás Budapesten és környékén, fix áron.
      </p>
      <p class="mt-2 text-xs text-slate-400">
        © {new Date().getFullYear()} DugulásSegély. Minden jog fenntartva.
      </p>
    </div>
    <div class="space-y-1 text-sm">
      <div>
        Telefon:{' '}
        <a href="tel:+36305382048" class="font-medium text-[#EF4444] hover:text-[#F97373]">
          +36 30 538 2048
        </a>
      </div>
      <div>
        E-mail:{' '}
        <a href="mailto:info@dugulassegely.hu" class="font-medium text-[#2563EB] hover:text-[#60A5FA]">
          info@dugulassegely.hu
        </a>
      </div>
      <div class="text-xs text-slate-400">
        Szolgáltatási terület: Budapest és 30 km-es körzete.
      </div>
    </div>
    <nav class="text-xs text-slate-900" aria-label="Jogi információk">
      <ul class="space-y-1">
        <li>
          <LegalModalLink id="impresszum" title="Impresszum">
            <ImpresszumContent />
          </LegalModalLink>
        </li>
        <li>
          <LegalModalLink id="adatkezeles" title="Adatkezelési tájékoztató">
            <AdatkezelesContent />
          </LegalModalLink>
        </li>
        <li>
          <LegalModalLink id="cookie" title="Cookie-kezelés">
            <CookieContent />
          </LegalModalLink>
        </li>
        <li>
          <LegalModalLink id="felhasznalasi-feltetelek" title="Felhasználási feltételek">
            <FelhasznalasContent />
          </LegalModalLink>
        </li>
      </ul>
    </nav>
  </div>
</footer>
