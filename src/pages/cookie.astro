---
import BaseLayout from '../layouts/BaseLayout.astro';
import CookieContent from '../components/legal/CookieContent.astro';
---

<BaseLayout
  title="Cookie-kezelési tájékoztató – DugulásSegély"
  description="Információk a dugulassegely.hu weboldalon használt cookie-król és a böngésző beállítási lehetőségeiről."
  canonical="https://dugulassegely.hu/cookie/"
>
  <section class="border-b border-slate-800 bg-[#020617]">
    <div class="mx-auto max-w-4xl px-4 py-12 md:py-16 text-sm text-slate-300">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-50 md:text-4xl">
        Cookie-kezelési tájékoztató
      </h1>
      <CookieContent />
    </div>
  </section>
</BaseLayout>

