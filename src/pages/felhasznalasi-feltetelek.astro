---
import BaseLayout from '../layouts/BaseLayout.astro';
import FelhasznalasContent from '../components/legal/FelhasznalasContent.astro';
---

<BaseLayout
  title="Felhasználási feltételek – dugulassegely.hu"
  description="A dugulassegely.hu weboldal használatára vonatkozó felhasználási feltételek és felelősségi szabályok."
  canonical="https://dugulassegely.hu/felhasznalasi-feltetelek/"
>
  <section class="border-b border-slate-800 bg-[#020617]">
    <div class="mx-auto max-w-4xl px-4 py-12 md:py-16 text-sm text-slate-300">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-50 md:text-4xl">
        Felhasználási feltételek
      </h1>
      <FelhasznalasContent />
    </div>
  </section>
</BaseLayout>

