---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImpresszumContent from '../components/legal/ImpresszumContent.astro';
---

<BaseLayout
  title="Impresszum – DugulásSegély duguláselhárítás"
  description="Üzemeltetői adatok, elérhetőségek és céginformációk a dugulassegely.hu weboldalhoz."
  canonical="https://dugulassegely.hu/impresszum/"
>
  <section class="border-b border-[var(--ds-border-subtle)] bg-[var(--ds-section)]">
    <div class="mx-auto max-w-4xl px-4 py-12 md:py-16 text-sm text-slate-700">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">
        Impresszum
      </h1>
      <ImpresszumContent />
    </div>
  </section>
</BaseLayout>

