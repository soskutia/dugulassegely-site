---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdatkezelesContent from '../components/legal/AdatkezelesContent.astro';
---

<BaseLayout
  title="Adatkezelési tájékoztató – DugulásSegély"
  description="Tájékoztató a dugulassegely.hu kapcsolatfelvételi űrlapján megadott személyes adatok kezeléséről."
  canonical="https://dugulassegely.hu/adatkezeles/"
>
  <section class="border-b border-slate-800 bg-[#020617]">
    <div class="mx-auto max-w-4xl px-4 py-12 md:py-16 text-sm text-slate-300">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-50 md:text-4xl">
        Adatkezelési tájékoztató
      </h1>
      <AdatkezelesContent />
    </div>
  </section>
</BaseLayout>

