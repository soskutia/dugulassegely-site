---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'DugulásSegély – 0–24 duguláselhárítás Budapesten',
  description = 'Gyors, megbízható duguláselhárítás Budapesten és környékén, azonnali kiszállással, rejtett költségek nélkül.',
  canonical,
} = Astro.props as Props;

const url = canonical ?? Astro.url.href;
const siteName = 'DugulásSegély';
const ogImage = '/og-default.jpg';
---

<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0F172A" />

    <title>{title}</title>

    <link rel="canonical" href={url} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="bg-[#0F172A] text-slate-50 antialiased">
    <Header />
    <main class="min-h-[60vh] bg-gradient-to-b from-[#020617] via-[#020617] to-[#020617]">
      <slot />
    </main>
    <Footer />
  </body>
</html>

